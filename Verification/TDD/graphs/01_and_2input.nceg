# AND 2-input: A AND B -> C
# Used by: cegAlgorithm (extractExpressions, deduceValue, checkRelation, calcTable, coverageTable)
#          decisionTable (simple AND, getFeasibleConditions, condition IDs)
#          learningMode (brute-force 4 columns, exclusion reasons, stats consistency)

p1: "A"
p2: "B"
p3: "C"

p3 := p1 AND p2

@layout {
  p1: (100, 100)
  p2: (100, 250)
  p3: (400, 175)
}
